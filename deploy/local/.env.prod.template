# Production Environment Variables
# Copy to /opt/clovercharts/.env.prod on the server and fill in real values.
# chmod 600 /opt/clovercharts/.env.prod
# NEVER commit the actual .env.prod file.

# --- Application ---
ENV=production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
ALLOWED_ORIGINS=["https://clovercharts.com","https://www.clovercharts.com"]

# --- Database (host-native PostgreSQL + TimescaleDB, same instance) ---
POSTGRES_USER=kuber
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=trading_platform
TIMESCALE_DB=trading_data_plane
DATABASE_URL=postgresql://kuber:CHANGE_ME_STRONG_DB_PASSWORD@host.docker.internal:5432/trading_platform
TIMESCALE_URL=postgresql+asyncpg://kuber:CHANGE_ME_STRONG_DB_PASSWORD@host.docker.internal:5432/trading_data_plane
BACKEND_DB_URL=postgresql+asyncpg://kuber:CHANGE_ME_STRONG_DB_PASSWORD@host.docker.internal:5432/trading_platform

# --- Redis ---
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Data Plane Celery (separate Redis DB) ---
DP_CELERY_BROKER_URL=redis://redis:6379/1
DP_CELERY_RESULT_BACKEND=redis://redis:6379/1
DP_REDIS_URL=redis://redis:6379/1

# --- JWT ---
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
# OPENAI_BASE_URL=  # Leave empty for OpenAI, set for LM Studio / compatible API

# --- Langfuse (optional) ---
LANGFUSE_ENABLED=false
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Market Data ---
FINNHUB_API_KEY=CHANGE_ME
# TIINGO_API_KEY=CHANGE_ME

# --- Broker (Alpaca) ---
ALPACA_API_KEY=CHANGE_ME
ALPACA_SECRET_KEY=CHANGE_ME
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Broker (OANDA) ---
# OANDA_API_KEY=CHANGE_ME
# OANDA_ACCOUNT_TYPE=practice
# OANDA_ACCOUNT_ID=CHANGE_ME

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SIGNAL_TOPIC=trading-signals

# --- Signal Generator ---
MARKET_DATA_PROVIDER=data_plane
DATA_PLANE_URL=http://data-plane:8000
ENABLE_MARKET_HOURS_CHECK=true

# --- Flower (Celery monitoring) ---
FLOWER_BASIC_AUTH=admin:CHANGE_ME_FLOWER_PASSWORD

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# --- Apple Push Notifications (optional) ---
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.clovercharts.app
# APNS_AUTH_KEY_PATH=/app/keys/AuthKey.p8

# --- Twilio SMS (optional) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# --- Subscription ---
ENFORCE_SUBSCRIPTION_LIMITS=false
DEFAULT_SUBSCRIPTION_TIER=enterprise

# --- Storage ---
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage/uploads
