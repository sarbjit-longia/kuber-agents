# Development Environment Variables
# Copy this to root/.env for local development

# Database
DATABASE_URL=postgresql://dev:devpass@localhost:5432/trading_platform

# Redis
REDIS_URL=redis://localhost:6379

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:4200
OPENROUTER_APP_NAME=CloverCharts
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# Langfuse tracing (optional)
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Self-hosted Langfuse only:
LANGFUSE_SELF_HOST_URL=http://localhost:3300
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse
LANGFUSE_NEXTAUTH_SECRET=change-me-langfuse-nextauth-secret
LANGFUSE_SALT=change-me-langfuse-salt
LANGFUSE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
LANGFUSE_S3_ACCESS_KEY_ID=minio
LANGFUSE_S3_SECRET_ACCESS_KEY=miniosecret
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_REGION=auto
LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/
LANGFUSE_DISABLE_SIGNUP=false

# Market Data
FINNHUB_API_KEY=your-finnhub-key-here

# Broker (Alpaca)
ALPACA_API_KEY=your-alpaca-key
ALPACA_SECRET_KEY=your-alpaca-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper trading

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Email (AWS SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
SES_FROM_EMAIL=noreply@yourdomain.com

# Application
ENV=development
DEBUG=true
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:4200

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Kafka (for signal system)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SIGNAL_TOPIC=trading-signals
BACKTEST_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
BACKTEST_KAFKA_SIGNAL_TOPIC=trading-signals-backtest
BACKTEST_RUNTIME_MODE=docker_container
BACKTEST_RUNTIME_IMAGE=clovercharts/backend:latest
BACKTEST_RUNTIME_DOCKER_NETWORK=
BACKTEST_RUNTIME_K8S_NAMESPACE=backtest
BACKTEST_RUNTIME_K8S_SERVICE_ACCOUNT=
BACKTEST_RUNTIME_K8S_IMAGE_PULL_POLICY=IfNotPresent
BACKTEST_RUNTIME_K8S_IMAGE_PULL_SECRETS=
BACKTEST_RUNTIME_K8S_JOB_TTL_SECONDS=3600
BACKTEST_RUNTIME_K8S_ACTIVE_DEADLINE_SECONDS=21600
BACKTEST_RUNTIME_EMBED_SIGNAL_GENERATOR=true
BACKTEST_RUNTIME_SIGNAL_GENERATOR_PORT=18007

# Internal service URLs
DATA_PLANE_URL=http://data-plane:8000
SIGNAL_GENERATOR_URL=http://signal-generator:8007

# Subscription & Billing
ENFORCE_SUBSCRIPTION_LIMITS=false      # Set to true to enforce tier limits
DEFAULT_SUBSCRIPTION_TIER=enterprise   # Default tier for all users in dev mode
